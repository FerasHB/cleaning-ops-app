# Supabase-Konfiguration für die Expo-App.
# Diese Datei ist eine VORLAGE — echte Werte gehören NUR in ein lokales .env
# (gitignored) bzw. in den EAS-/CI-Env-Store, niemals ins Repository.

# Projekt-URL (öffentlich, unkritisch).
EXPO_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"

# CLIENT-Key: NUR der Publishable-/Anon-Key (sb_publishable_… oder Legacy-anon-JWT).
# Dieser Key ist für den Client bestimmt und wird durch RLS abgesichert.
#
# ⚠️  NIEMALS einen Secret-/Service-Role-Key hier eintragen:
#     - sb_secret_… oder ein service_role-JWT hebeln RLS aus.
#     - Alles mit dem Präfix EXPO_PUBLIC_ landet im App-Bundle (öffentlich).
#     - Der Service-Role-/Secret-Key gehört AUSSCHLIESSLICH serverseitig
#       (Edge Functions erhalten ihn automatisch über Deno.env, siehe
#       supabase/functions/*). lib/supabase.ts bricht im Dev-Modus ab, wenn
#       hier versehentlich ein Secret-Key steht.
EXPO_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_<...>"
